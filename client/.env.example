# ── AI Travel Concierge (Groq) ─────────────────────────────────────────────
# Copy this file to `.env.local` (which is git-ignored) and fill in your key.
# Get a free key at https://console.groq.com/keys
#
# ⚠️  This is a frontend-only app, so this key is bundled into the browser build
#     and is visible to anyone. Use a key with tight rate limits, and for
#     production move these calls behind a small backend proxy instead.

VITE_GROQ_API_KEY=

# Optional — override the model (default: llama-3.3-70b-versatile)
# VITE_GROQ_MODEL=llama-3.3-70b-versatile
